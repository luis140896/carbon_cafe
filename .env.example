# ============================================================
# SISTEMA POS MORALES - Plantilla de variables (.env)
# ============================================================
# 1. Copia este archivo como `.env` (o `.env.deploy`).
# 2. Reemplaza TODOS los valores de ejemplo por los reales.
# 3. Sube este archivo a Render con "Add from env" y a Vercel
#    en Project Settings → Environment Variables (Production).
# 4. Elimina el archivo `.env` antes de hacer commit para no subir
#    credenciales. Deja solo este `.env.example` en el repo.
# ============================================================

##############################################################
# Backend (Render / ejecución local)
##############################################################

# Perfil Spring activo (Render/producción)
SPRING_PROFILES_ACTIVE=prod

# Puerto por defecto; Render inyecta su propio $PORT
PORT=8080

# -----------------------------------------------------------
# Base de datos PostgreSQL (Neon)
# -----------------------------------------------------------
# Si Render solo recibe variables individuales, completa HOST/PORT/etc.
DB_HOST=ep-summer-surf-aik1s2q2-pooler.c-4.us-east-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USERNAME=neondb_owner
DB_PASSWORD=cambia_esto_por_password_seguro

# Si prefieres una sola variable, comenta las anteriores y usa esta:
# DATABASE_URL=jdbc:postgresql://neondb_owner:TU_PASSWORD@ep-summer-surf-aik1s2q2-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Requiere SSL en Neon
DB_SSLMODE=require

# -----------------------------------------------------------
# Seguridad y CORS
# -----------------------------------------------------------
# Generar con: openssl rand -base64 64  (mínimo 64 caracteres)
JWT_SECRET=cambia_esto_por_una_cadena_aleatoria_de_al_menos_64_caracteres_muy_segura

# Lista separada por comas con tus dominios reales (Render, Vercel, etc.)
CORS_ORIGINS=https://tu-frontend.vercel.app,https://tu-dominio-personal.com

##############################################################
# Frontend (Vercel / ejecución local)
##############################################################

# URL pública del backend desplegado (añade /api)
VITE_API_URL=https://tu-backend.onrender.com/api

# Endpoint SSE/WebSocket (solo si el frontend lo usa)
VITE_SSE_URL=https://tu-backend.onrender.com/api/sse/events

# Dominio para archivos estáticos u otros servicios opcionales
# VITE_ASSETS_URL=https://cdn.tu-dominio.com

##############################################################
# Recordatorios rápidos
##############################################################
# - Render: Dashboard → New Web Service → Docker → env → "Add from env" y
#   sube este archivo (ya con datos reales). Luego puedes editar cada variable.
# - Neon: no necesita este archivo, pero los valores aquí deben coincidir con
#   la cadena de conexión mostrada en tu panel (host, usuario, password).
# - Vercel: Project Settings → Environment Variables → pega VITE_* para
#   Production (y Preview si quieres). Después ejecuta "Redeploy".
# - Nunca compartas el archivo `.env` por chat o repositorios públicos.
